@model BlogCochesSolution.Models.ViewModels.HomeVM


<!--Slider-->
<div id="sliderImagenes" class="carousel slide carousel-fade shadow-lg" data-bs-ride="carousel">
    <div class="carousel-indicators">

        @{
            var slidersActivos = Model.Sliders.Where(s => s.Estado).ToList();
        }
        @for (int i = 0; i < slidersActivos.Count; i++)
        {
            <button type="button" data-bs-target="#sliderImagenes" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")" aria-current="@(i == 0 ? "true" : "false")"></button>
        }
    </div>

    <div class="carousel-inner">

        @for (int i = 0; i < slidersActivos.Count; i++)
        {
            <div class="carousel-item @(i == 0 ? "active" : "") slider-hero" data-bs-interval="5000">
                <img src="@Url.Content(slidersActivos[i].UrlImagen)" class="slider-img" alt="Slider Image" />

                <div class="slider-overlay"></div>

                <div class="slider-content">
                    <div class="slider-glass">
                        <span class="badge bg-primary mb-3 px-3 py-2" style="border-radius: 50px; font-weight: 600;">Destacado</span>
                        <h1 class="mb-0">
                            @Html.Raw(slidersActivos[i].Nombre)
                        </h1>
                    </div>
                </div>
            </div>
         }
    </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#sliderImagenes" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Anterior</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#sliderImagenes" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Siguiente</span>
            </button>
        
    </div>
</div>
<!--Cierra Slider-->