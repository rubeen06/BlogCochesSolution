@page
@using BlogCoches.Areas.Identity.Pages.Account
@model LoginModel
@{
    ViewData["Title"] = "Iniciar Sesión";
}

<link rel="stylesheet" href="~/css/account.css" />

<div class="container account-body">
    <div class="row justify-content-center w-100">
        <div class="col-md-5">
            <div class="account-card">
                <div class="text-center mb-4">
                    <h1 class="account-title">Bienvenido de nuevo</h1>
                    <p class="text-muted">Accede a tu panel de control.</p>
                </div>

                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control" placeholder="Email" />
                        <label asp-for="Input.Email"><i class="bi bi-envelope me-2"></i>Email</label>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="Input.Password" class="form-control" placeholder="Password" />
                        <label asp-for="Input.Password"><i class="bi bi-lock me-2"></i>Contraseña</label>
                    </div>

                    <button id="login-submit" type="submit" class="w-100 btn btn-primary btn-account btn-lg mb-3">
                        Entrar <i class="bi bi-box-arrow-in-right ms-2"></i>
                    </button>

                    <div class="text-center">
                        <p class="mb-1"><a class="account-link" asp-page="./ForgotPassword">¿Olvidaste tu contraseña?</a></p>
                        <p><a class="account-link fw-bold text-primary" asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Crear una cuenta nueva</a></p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
