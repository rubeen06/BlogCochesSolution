@page
@using BlogCoches.Areas.Identity.Pages.Account
@model ForgotPasswordModel
@{
    ViewData["Title"] = "¿Olvidaste tu contraseña?";
}

<link rel="stylesheet" href="~/css/account.css" />

<div class="container account-body">
    <div class="row justify-content-center w-100">
        <div class="col-md-4">
            <div class="account-card text-center">
                <div class="mb-4">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                        <i class="bi bi-shield-lock fs-1"></i>
                    </div>
                    <h1 class="account-title fs-3">Recuperar acceso</h1>
                    <p class="text-muted small">Te enviaremos un enlace para restablecer tu contraseña.</p>
                </div>

                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    <div class="form-floating mb-4">
                        <input asp-for="Input.Email" class="form-control" placeholder="Email" />
                        <label asp-for="Input.Email">Introduce tu Email</label>
                    </div>
                    <button type="submit" class="w-100 btn btn-primary btn-account btn-lg">
                        Enviar Enlace
                    </button>
                    <a asp-page="./Login" class="btn btn-link account-link mt-3">Volver al inicio de sesión</a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
