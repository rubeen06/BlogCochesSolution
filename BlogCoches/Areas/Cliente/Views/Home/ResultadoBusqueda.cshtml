@using BlogCochesSolution.Models
@model ListaPaginada<Articulo>

@{
    ViewData["Title"] = "Resultados de búsqueda";
}



<div class="container py-4">
    <div class="search-header d-flex justify-content-between align-items-end">
        <div>
            <h2 class="fw-bold text-dark mb-0">Resultados para: <span class="text-primary">"@Model.SearchString"</span></h2>
            <p class="text-muted mb-0">Hemos encontrado @Model.Count() entradas</p>
        </div>
        <a asp-controller="Home" asp-action="Index" class="text-decoration-none small fw-bold text-secondary">
            <i class="bi bi-x-circle me-1"></i> Limpiar búsqueda
        </a>
    </div>

    @if (Model.Count() > 0)
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var articulo in Model)
            {
                <div class="col">
                    <div class="card search-result-card h-100">
                        <div class="img-wrapper-search">
                            <img src="@articulo.UrlImagen" alt="@articulo.Nombre">
                        </div>
                        <div class="card-body d-flex flex-column p-4">
                            <h5 class="card-title fw-bold text-dark mb-3">@articulo.Nombre</h5>
                            <div class="mt-auto">
                                <a asp-action="Detalle"
                                   asp-route-id="@articulo.Id"
                                   class="btn-pro">
                                    Explorar Detalle
                                </a>
                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="mt-5">
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                        <a class="page-link border-0 shadow-sm mx-1 rounded-3"
                           asp-controller="Home" asp-action="ResultadoBusqueda"
                           asp-route-page="@(Model.PageIndex - 1)"
                           asp-route-searchString="@Model.SearchString">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                            <a class="page-link border-0 shadow-sm mx-1 rounded-3 @(i == Model.PageIndex ? "bg-primary text-white" : "text-dark")"
                               asp-controller="Home" asp-action="ResultadoBusqueda"
                               asp-route-page="@i"
                               asp-route-searchString="@Model.SearchString">@i</a>
                        </li>
                    }

                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                        <a class="page-link border-0 shadow-sm mx-1 rounded-3"
                           asp-controller="Home" asp-action="ResultadoBusqueda"
                           asp-route-page="@(Model.PageIndex + 1)"
                           asp-route-searchString="@Model.SearchString">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    }
    else
    {
        <div class="empty-state text-center mt-4">
            <i class="bi bi-search text-muted" style="font-size: 3rem;"></i>
            <h3 class="mt-3 fw-bold">No hay resultados</h3>
            <p class="text-muted">Intenta con otras palabras clave o explora las categorías.</p>
            <a asp-action="Index" class="btn btn-primary rounded-pill px-4 mt-2">Volver al inicio</a>
        </div>
    }
</div>