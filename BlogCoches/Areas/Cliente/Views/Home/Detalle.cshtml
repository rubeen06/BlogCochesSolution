@model BlogCochesSolution.Models.Articulo
@{
    ViewData["Title"] = Model.Nombre;
}



<article class="bg-white">
    <header class="article-header">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-10 text-center">
                    <nav class="mb-3">
                        <a asp-action="Index" class="btn-back">
                            <i class="bi bi-arrow-left"></i> Volver al Blog
                        </a>
                    </nav>
                    <span class="article-category">Motor & Lifestyle</span>
                    <h1 class="article-title">@Model.Nombre</h1>
                    <div class="article-meta justify-content-center">
                        <span><i class="bi bi-calendar3 me-2"></i>@Model.FechaCreacion.ToString("dd MMMM, yyyy")</span>
                        <span class="text-muted">|</span>
                        <span><i class="bi bi-clock me-2"></i> 5 min de lectura</span>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-11">
                <div class="article-image-container">
                    <img src="@Model.UrlImagen" class="article-image" alt="@Model.Nombre" />
                </div>
            </div>
        </div>
    </div>

    <section class="container pb-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="article-content">
                    @Html.Raw(Model.Descripcion)
                </div>

                <hr class="my-5 opacity-25" />

                <div class="d-flex justify-content-between align-items-center bg-light p-4 rounded-4">
                    <div>
                        <p class="mb-0 fw-bold">¿Te ha gustado este artículo?</p>
                        <small class="text-muted">Compártelo con otros entusiastas de los coches.</small>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-dark btn-sm rounded-circle"><i class="bi bi-facebook"></i></button>
                        <button class="btn btn-outline-dark btn-sm rounded-circle"><i class="bi bi-twitter-x"></i></button>
                        <button class="btn btn-outline-dark btn-sm rounded-circle"><i class="bi bi-link-45deg"></i></button>
                    </div>
                </div>
            </div>
        </div>
    </section>
</article>