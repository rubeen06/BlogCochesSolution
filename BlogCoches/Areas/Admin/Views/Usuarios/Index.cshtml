@using BlogCochesSolution.Models
@model IEnumerable<ApplicationUser>

@{
    ViewData["Title"] = "Lista de Usuarios";
}
<div class="container pb-5">
    <div class="card shadow-sm border-0 mt-5" style="border-radius: 20px; overflow: hidden;">

        <div class="card-header bg-white border-0 py-4 px-4">
            <div class="row align-items-center">
                <div class="col-md-8 text-center text-md-start">
                    <h2 class="fw-bold text-dark mb-1">
                        <i class="bi bi-person-fill text-primary me-2"></i>Lista de Usuarios
                    </h2>
                </div>
                <div class="col-md-4 text-center text-md-end mt-3 mt-md-0">
                    <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary px-4 py-2 shadow-sm rounded-pill fw-bold">
                        <i class="bi bi-plus-lg me-1"></i> Nuevo usuario
                    </a>
                </div>
            </div>
        </div>

    <br />
    <br />



        <div class="card-body px-4 pb-4">
            <div class="table-responsive">
   @if (Model.Count() > 0)
    {
                <table class="table admin-table align-middle">
                        <thead class="text-secondary small text-uppercase">
                <tr>
                                <th class="border-0 ps-3">Id</th>
                                <th class="border-0">Nombre </th>
                                <th class="border-0">Email</th>
                                <th class="border text-center">Acciones</th>
                </tr>
            </thead>
            <tbody class="small">
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(m => item.Id)</td>
                        <td>@Html.DisplayFor(m => item.Nombre)</td>
                        <td>@Html.DisplayFor(m => item.Email)</td>
                        <td>
                            @if(item.LockoutEnd == null || item.LockoutEnd < DateTime.Now)
                            {
                                <a class="btn btn-success text-white" asp-action="Bloquear" 
                                    style="width:140px" asp-route-id="@item.Id">
                                    Bloquear
                                </a>
                            }
                            else
                            {
                                <a class="btn btn-danger text-white" asp-action="Desbloquear" 
                                    style="width:140px" asp-route-id="@item.Id">
                                    Desbloquear
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
        </div>
    
    </div>
</div>
