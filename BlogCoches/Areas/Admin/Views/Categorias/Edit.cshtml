@model BlogCochesSolution.Models.Categoria
@{
    ViewData["Title"] = "Editar Categoría";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <div class="d-flex justify-content-between align-items-center mb-4 mt-5">
                <div>
                    <h2 class="fw-bold text-dark mb-0">Editar Categoría</h2>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                    <i class="bi bi-arrow-left me-2"></i> Cancelar
                </a>
            </div>
            <form method="POST" asp-action="Edit" enctype="multipart/form-data" class="edit-container-pro">
                <input type="hidden" asp-for=Id" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                <div class="row">
                    <div class="col-md-7">
                        <div class="mb-4">
                            <label asp-for="Nombre" class="form-label-pro">Título</label>
                            <input asp-for="Nombre" class="form-control-pro w-100" />
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>

                        
                        <div class="mb-4">
                            <label asp-for="Orden" class="form-label-pro">Contenido</label>
                            <input asp-for="Orden" id="Contenido" class="form-control-pro w-100"/>
                            <span asp-validation-for="Orden" class="text-danger small"></span>
                        </div>
                        
                    </div>
                </div>



                <div class="d-grid gap-2 col-6 mx-auto">
                        <button type="submit" class="btn-update shadow-sm">
                            <i class="bi bi-check-circle me-2"></i> Guardar Cambios
                        </button>
                    </div>

            </form>

            <div class="container">
   
</div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}