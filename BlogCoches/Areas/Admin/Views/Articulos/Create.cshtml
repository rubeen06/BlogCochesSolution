@model BlogCochesSolution.Models.ViewModels.ArticuloVM
@{
    ViewData["Title"] = "Crear Artículo";
}


<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-9">

            <div class="text-center mb-4 mt-5">
                <h2 class="fw-bold text-slate-800">Crear Artículo</h2>
                <p class="text-muted">Crea un nuevo artículo con formato enriquecido para tu blog.</p>
            </div>

            <form method="POST" asp-action="Create" enctype="multipart/form-data" class="form-container-pro">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                <div class="row">
                    <div class="col-md-8">
                        <div class="mb-4">
                            <label asp-for="Articulo.Nombre" class="form-label-pro">Título del Artículo</label>
                            <input asp-for="Articulo.Nombre" class="form-control-pro w-100" placeholder="Ej: Las mejores rutas en coche por España" />
                            <span asp-validation-for="Articulo.Nombre" class="text-danger small"></span>
                        </div>

                        <div class="mb-4 editor-container">
                            <label asp-for="Articulo.Descripcion" class="form-label-pro">Cuerpo del Artículo</label>
                            <textarea asp-for="Articulo.Descripcion" id="Contenido" class="form-control-pro"></textarea>
                            <span asp-validation-for="Articulo.Descripcion" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="mb-4">
                            <label class="form-label-pro">Categoría</label>
                            @Html.DropDownListFor(m => m.Articulo.CategoriaId, Model.ListaCategorias,
                            "- Seleccionar -", new { @class = "form-select form-control-pro" })
                            <span asp-validation-for="Articulo.CategoriaId" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label-pro">Imagen de Portada</label>
                            <div class="input-group">
                                <input type="file" class="form-control form-control-pro" name="archivos" id="subidaArchivo" accept="image/*" onchange="previewImage(event)" />
                            </div>
                            <img id="imagePreview" src="#" alt="Vista previa" />
                            <span asp-validation-for="Articulo.UrlImagen" class="text-danger small"></span>
                        </div>

                        <div class="alert alert-info border-0 shadow-sm small">
                            <i class="bi bi-lightbulb me-2"></i> <strong>Tip:</strong> Usa imágenes de alta resolución (mínimo 1200px) para una mejor apariencia.
                        </div>
                    </div>
                </div>

                <hr class="my-4 opacity-25">

                <div class="d-flex justify-content-between align-items-center">
                    <partial name="_VistaCrearVolver" />
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/simplemde@1.11.2/dist/simplemde.min.css">
    <script src="https://cdn.jsdelivr.net/npm/simplemde@1.11.2/dist/simplemde.min.js"></script>

    <script>
        // Inicializar Editor Moderno
        var simplemde = new SimpleMDE({
            element: document.getElementById("Contenido"),
            spellChecker: false,
            placeholder: "Escribe aquí la historia...",
            status: false
        });

        // Previsualización de imagen dinámica
        function previewImage(event) {
            var reader = new FileReader();
            reader.onload = function() {
                var output = document.getElementById('imagePreview');
                output.src = reader.result;
                output.style.display = 'block';
            };
            reader.readAsDataURL(event.target.files[0]);
        }
    </script>
}